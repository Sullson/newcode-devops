# Local environment for the FIRST (manual) terraform run on your machine.
#
#   cp .env.example .env          # .env is gitignored — REAL values are safe in .env,
#                                 # NEVER in .env.example (this file is committed).
#   az login                      # local auth = your Azure CLI session
#   set -a; source .env; set +a   # load the vars
#   bash scripts/bootstrap-backend.sh
#   terraform -chdir=terraform init
#   terraform -chdir=terraform apply        # creates the persistent infra
#
# There is NO Azure client secret here — CI authenticates via OIDC, you via az login.
# The only real secret below is the Cloudflare API token.

# --- Azure context (identifiers, not secrets) ---
export ARM_SUBSCRIPTION_ID=REPLACE_ME
export ARM_TENANT_ID=REPLACE_ME

# --- Terraform input variables (provider + resources read these) ---
export TF_VAR_subscription_id="$ARM_SUBSCRIPTION_ID"
export TF_VAR_tenant_id="$ARM_TENANT_ID"
export TF_VAR_cloudflare_account_id=REPLACE_ME

# --- Cloudflare API token (the cloudflare provider reads this env var directly) ---
# REAL SECRET. Token scope: Zone:DNS:Edit on msulawiak.pl + Account:Cloudflare Tunnel:Edit.
export CLOUDFLARE_API_TOKEN=REPLACE_ME

# --- Optional ---
# export LOCATION=swedencentral   # state-storage region (used by bootstrap-backend.sh)
