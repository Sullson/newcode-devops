# --- Node / Astro (app/) ---
node_modules/
dist/
.astro/
.output/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# --- Terraform ---
.terraform/
.terraform.lock.hcl.bak
*.tfstate
*.tfstate.*
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json
# tfvars hold real config (possibly sensitive) — only the .example is tracked
*.tfvars
*.tfvars.json
!*.tfvars.example

# --- Env / secrets (never commit real values) ---
.env
.env.*
!.env.example
*.pem
*.key

# --- Editors / OS junk ---
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*~
