---
// Build-time evidence card. Reads the newest docs/evidence/aks-proof-*.md the
// deploy-aks workflow committed and surfaces its real, public facts: the run
// timestamp, the commit, the cosign-verified image digest, and the aks-*-vmss
// node it ran on. No runtime fetch — parsed at build, so it respects the
// zero-external-requests posture and stays visible even when the cluster is down.
//
// Honest by construction: this is "a real signed deploy happened and was
// recorded", NOT "we're on AKS this second" (that's the live /proof.json panel).
// If the evidence can't be found/parsed (e.g. the in-image build has no docs/
// context), it degrades to a {{TODO}}-style link rather than inventing values.
import fs from 'node:fs';
import path from 'node:path';

const REPO = 'https://github.com/sullson/newcode-devops';

function findEvidenceDir(): string | null {
  for (const rel of ['../docs/evidence', 'docs/evidence', '../../docs/evidence']) {
    const dir = path.resolve(process.cwd(), rel);
    try {
      if (fs.statSync(dir).isDirectory()) return dir;
    } catch {
      /* keep looking */
    }
  }
  return null;
}

function match(re: RegExp, text: string): string | null {
  const m = text.match(re);
  return m ? m[1] : null;
}

interface Run {
  file: string;
  timestamp: string | null;
  commit: string | null;
  digest: string | null;
  node: string | null;
  appCode: string | null;
  metricsCode: string | null;
}

let run: Run | null = null;
const dir = findEvidenceDir();
if (dir) {
  try {
    const files = fs
      .readdirSync(dir)
      .filter((f) => /^aks-proof-.*\.md$/.test(f))
      .sort()
      .reverse();
    if (files.length) {
      const file = files[0];
      const text = fs.readFileSync(path.join(dir, file), 'utf8');
      run = {
        file,
        timestamp: match(/#\s*AKS proof\s*[—-]\s*(\S+)/, text) ?? file.replace(/^aks-proof-|\.md$/g, ''),
        commit: match(/Commit:\s*`([0-9a-f]{7,40})`/, text),
        digest: match(/"docker-manifest-digest":"(sha256:[0-9a-f]+)"/, text),
        node: match(/(aks-[a-z0-9-]*vmss[0-9a-z]+)/i, text),
        appCode: match(/healthz HTTP `(\d{3})`/, text),
        metricsCode: match(/api\/health HTTP `(\d{3})`/, text),
      };
    }
  } catch {
    run = null;
  }
}

const shortDigest = run?.digest ? run.digest.slice(0, 17) + '…' : null;
const shortCommit = run?.commit ? run.commit.slice(0, 7) : null;
---

{run ? (
  <div class="evidence-card">
    <div class="evidence-card__bar">
      <span>aks-proof · {run.timestamp}</span>
    </div>
    <div class="evidence-card__body">
      <dl class="kv">
        {shortCommit && (
          <>
            <dt>commit</dt>
            <dd>{shortCommit}</dd>
          </>
        )}
        {shortDigest && (
          <>
            <dt>image</dt>
            <dd title={run.digest}>
              <span class="ok">✓ cosign verified</span> {shortDigest}
            </dd>
          </>
        )}
        {run.node && (
          <>
            <dt>node</dt>
            <dd>{run.node}</dd>
          </>
        )}
        {run.appCode && (
          <>
            <dt>app /healthz</dt>
            <dd>
              <span class="ok">HTTP {run.appCode}</span>
            </dd>
          </>
        )}
      </dl>
      <p class="evidence-card__foot">
        Captured by the deploy-aks pipeline and committed to the repo —{' '}
        <a
          href={`${REPO}/blob/main/docs/evidence/${run.file}`}
          target="_blank"
          rel="noopener noreferrer"
          >view the full run ↗</a
        >.
      </p>
    </div>
  </div>
) : (
  <div class="evidence-card">
    <div class="evidence-card__body">
      <p class="evidence-card__foot">
        <span class="todo">{'{{TODO: evidence not found at build time}}'}</span> —{' '}
        <a
          href={`${REPO}/tree/main/docs/evidence`}
          target="_blank"
          rel="noopener noreferrer"
          >browse the committed run evidence ↗</a
        >.
      </p>
    </div>
  </div>
)}
