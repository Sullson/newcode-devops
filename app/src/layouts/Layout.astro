---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Senior DevOps — production AI infrastructure',
  description = 'Production-grade Azure/AKS platform engineering: Terraform, Helm, GitHub Actions, observability, multi-tenant isolation, zero inbound ports, zero secrets in a public repo.',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="color-scheme" content="dark" />
    <meta name="theme-color" content="#0b0e14" />

    <!-- Open Graph: text-only, no remote image to keep zero external requests. -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />

    <!-- No analytics, no trackers, no third-party scripts: a privacy posture
         that matches a legal/professional-services AI audience. -->
  </head>
  <body>
    <slot />
  </body>
</html>
