---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Michał Sulawiak - Senior DevOps for production AI infrastructure',
  description = 'Senior Cloud Architect & DevOps/SRE. A production Azure/AKS platform - Terraform, Helm, GitHub Actions, OIDC, signed images, observability, outbound-only networking, no secrets in the repo. The site is deployed by the pipelines it documents.',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="color-scheme" content="light" />
    <meta name="theme-color" content="#ffffff" />

    <!-- Self-hosted fonts (same families as newcode.ai). Preloaded so the first
         paint uses them; crossorigin is required for font preloads even
         same-origin. No request leaves this origin. -->
    <link rel="preload" href="/fonts/dm-sans-latin.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/source-serif-4-latin.woff2" as="font" type="font/woff2" crossorigin />

    <!-- Open Graph: text-only, no remote image, so the page stays at zero
         external requests. -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />

    <!-- No analytics, no trackers, no third-party scripts. -->
  </head>
  <body>
    <slot />
  </body>
</html>
