{
  "__comment": "RED dashboard for cv-site (nginx-prometheus-exporter). Datasource is a Prometheus-compatible source (Azure Managed Prometheus via Managed Grafana). nginx exporter exposes counters: nginx_http_requests_total, nginx_connections_*. nginx stub_status has no per-status-code or latency histograms, so error rate is approximated from connection-handling and latency panels are placeholders to be backed by an nginx log/OTel histogram. See SLO.md.",
  "uid": "cv-site-red",
  "title": "cv-site — RED (Rate / Errors / Duration)",
  "tags": ["cv-site", "red", "nginx"],
  "timezone": "utc",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Managed Prometheus", "value": "Managed Prometheus" },
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Rate — requests/sec",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(rate(nginx_http_requests_total{namespace=\"cv\"}[5m]))",
          "legendFormat": "requests/s"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Errors — dropped vs accepted connections/sec",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "cps" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(rate(nginx_connections_accepted{namespace=\"cv\"}[5m])) - sum(rate(nginx_connections_handled{namespace=\"cv\"}[5m]))",
          "legendFormat": "dropped/s"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(rate(nginx_connections_handled{namespace=\"cv\"}[5m]))",
          "legendFormat": "handled/s"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Errors — drop ratio (%)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.001 },
              { "color": "red", "value": 0.01 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "(sum(rate(nginx_connections_accepted{namespace=\"cv\"}[5m])) - sum(rate(nginx_connections_handled{namespace=\"cv\"}[5m]))) / clamp_min(sum(rate(nginx_connections_accepted{namespace=\"cv\"}[5m])), 1)"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Active connections",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(nginx_connections_active{namespace=\"cv\"})",
          "legendFormat": "active"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Duration — p50 (request latency)",
      "description": "Latency requires an nginx log/OTel histogram (nginx_http_request_duration_seconds_bucket). stub_status does not expose latency; wire a histogram exporter to populate. See SLO.md.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.50, sum(rate(nginx_http_request_duration_seconds_bucket{namespace=\"cv\"}[5m])) by (le))",
          "legendFormat": "p50"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Duration — p95 (request latency)",
      "description": "Same histogram caveat as p50.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.95, sum(rate(nginx_http_request_duration_seconds_bucket{namespace=\"cv\"}[5m])) by (le))",
          "legendFormat": "p95"
        }
      ]
    }
  ]
}
