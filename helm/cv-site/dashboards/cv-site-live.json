{
  "__comment": "PUBLIC live dashboard for the in-cluster Grafana (anonymous viewer). Only panels backed by real nginx stub_status data — no latency placeholders, so a visitor never sees an empty 'No data' panel. The full RED dashboard (incl. latency placeholders) is grafana/dashboard-red.json, used by the Azure Managed Grafana production variant. Datasource uid is the provisioned in-cluster Prometheus.",
  "uid": "cv-site-live",
  "title": "cv-site — live (Rate / Errors / connections)",
  "tags": ["cv-site", "live", "nginx"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Rate — requests/sec",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(nginx_http_requests_total[1m]))",
          "legendFormat": "requests/s"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Connections handled / accepted per sec",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "cps" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(nginx_connections_accepted[1m]))",
          "legendFormat": "accepted/s"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(nginx_connections_handled[1m]))",
          "legendFormat": "handled/s"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Active connections",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 9 },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null } ] } }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(nginx_connections_active)"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Dropped-connection ratio",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 9 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.001 },
              { "color": "red", "value": 0.01 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "(sum(rate(nginx_connections_accepted[5m])) - sum(rate(nginx_connections_handled[5m]))) / clamp_min(sum(rate(nginx_connections_accepted[5m])), 1)"
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Total requests handled",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 9 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(nginx_http_requests_total)"
        }
      ]
    }
  ]
}
